PORT=3000

# PostgreSQL — Neon 云数据库（推荐，无需本地安装）
# 1. 注册 https://console.neon.tech
# 2. 创建项目 → Connect → 关闭 Connection pooling → 复制 URI
# 3. 粘贴到下方（必须含 sslmode=require）
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# 本地 PostgreSQL / Docker 备选
# DATABASE_URL="postgresql://postgres:tuhui@localhost:5432/tuhui?schema=public"

# DeepSeek AI
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 高德 Web 服务 Key（地理编码 / POI 搜索，与 H5 地图 JS Key 不同）
# 控制台 https://console.amap.com → 应用管理 → 添加 Key → Web 服务
AMAP_WEB_KEY=

# JWT（生产环境请改为随机长字符串）
JWT_SECRET=change-me-in-production

# 初始化攻略库（30 篇热门目的地精选攻略，供 AI Agent 检索）
# cd apps/server && npx prisma migrate deploy && npm run prisma:seed
